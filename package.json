{
  "name": "realpolitik-core",
  "version": "0.1.0",
  "description": "Motor de simulación geopolítica determinista para juego de estrategia en tiempo real",
  "main": "server/main.js",
  "type": "module",
  "scripts": {
    "start": "node server/main.js",
    "dev": "node --watch server/main.js",
    "test": "node --test tests/**/*.test.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:integration": "node --test tests/integration/**/*.test.js",
    "lint": "eslint . --ext .js",
    "validate:determinism": "node tests/integration/determinism.test.js"
  },
  "keywords": [
    "geopolitics",
    "simulation",
    "strategy",
    "deterministic",
    "game-engine"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0"
  }
}