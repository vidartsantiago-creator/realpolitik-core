{
     	  "name": "realpolitik-core",
     	  "version": "0.1.0",
     	  "description": "Motor de simulación geopolítica determinista para juego de estrategia en tiempo real",
     	  "main": "server/main.js",
     	  "type": "module",
     	  "scripts": {
     	       	  "start": "node server/main.js",
     	       	  "dev": "node --watch server/main.js",
     	       	  "test:integration": "node --test tests/integration/*.test.js",
     	       	  "test:unit": "node --test tests/unit/*.test.js",
     	       	  "test": "npm run test:unit && npm run test:integration",
     	       	  "lint": "eslint ./ tests/",
     	       	  "validate:determinism": "node tests/integration/determinism.test.cjs"
     	  },
     	  "keywords": [
     	       	  "geopolitics",
     	       	  "simulation",
     	       	  "strategy",
     	       	  "deterministic",
     	       	  "game-engine"
     	  ],
     	  "author": "",
     	  "license": "MIT",
     	  "engines": {
     	       	  "node": ">=18.0.0"
     	  },
     	  "dependencies": {
     	       	  "ajv": "^8.20.0",
     	       	  "express": "^5.2.1",
     	       	  "ws": "^8.21.0"
     	  },
     	  "devDependencies": {
     	       	  "eslint": "^8.56.0"
     	  }
}
