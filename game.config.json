{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "RealPolitik Core Configuration",
  "description": "Configuración centralizada para el motor de juego, persistencia, red y reglas de negocio.",
  "core": {
    "seed": 42,
    "tickRate": 1000,
    "mode": "continuous",
    "maxHistoryTicks": 120
  },
  "persistence": {
    "enabled": true,
    "filePath": "./data/world.json",
    "autoSaveInterval": 10,
    "backupOnSave": true,
    "maxBackups": 5
  },
  "network": {
    "port": 8080,
    "connectionTimeout": 30000,
    "heartbeatInterval": 5000,
    "maxClients": 100
  },
  "rules": {
    "economy": {
      "baseIncome": {
        "gold": 10,
        "food": 5
      },
      "maxDebt": -1000,
      "bankruptcyThreshold": -2000
    },
    "units": {
      "infantry": {
        "cost": { "gold": 50, "food": 10 },
        "upkeep": { "gold": 1, "food": 1 },
        "movement": 2,
        "strength": 10
      },
      "tank": {
        "cost": { "gold": 200, "food": 50 },
        "upkeep": { "gold": 5, "food": 3 },
        "movement": 3,
        "strength": 40
      },
      "ship": {
        "cost": { "gold": 300, "food": 100 },
        "upkeep": { "gold": 8, "food": 5 },
        "movement": 4,
        "strength": 60
      },
      "scout": {
        "cost": { "gold": 30, "food": 5 },
        "upkeep": { "gold": 1, "food": 0 },
        "movement": 5,
        "strength": 5
      }
    },
    "diplomacy": {
      "relationBounds": {
        "min": -100,
        "max": 100
      },
      "thresholds": {
        "war": -80,
        "neutral": [-20, 20],
        "ally": 60
      },
      "actionCosts": {
        "propose_alliance": 50,
        "declare_war": 0,
        "send_aid": 100
      },
      "naturalDecay": -0.5
    },
    "factions": {
      "loyaltyBounds": {
        "min": 0,
        "max": 100
      },
      "plotThresholds": {
        "minor": 30,
        "major": 60,
        "critical": 80
      }
    }
  }
}